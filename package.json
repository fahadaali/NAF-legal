{
  "name": "naf-legal",
  "version": "1.0.0",
  "description": "منصة مستشار ناف — منصة استشارات قانونية ذكية باللغة العربية على Cloudflare",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:web": "npm --prefix web run dev",
    "build:web": "npm --prefix web run build",
    "deploy": "npm run build:web && wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply naf_legal --local",
    "db:migrate:remote": "wrangler d1 migrations apply naf_legal --remote",
    "typecheck": "tsc --noEmit",
    "seed": "wrangler d1 execute naf_legal --local --file=./migrations/0002_seed.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "typescript": "^5.6.2",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "hono": "^4.6.3"
  }
}
